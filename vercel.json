{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://mergex-api-vercel.vercel.app/api/:path*"
    },
    {
      "source": "/reposcan/api/:path*",
      "destination": "https://mergex-reposcan-production.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
